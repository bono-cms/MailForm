<?php

use Krystal\Widget\GridView\GridViewWidget;
use Krystal\Form\Element;
use Cms\Service\LanguageManager;
use Cms\View\Icon;

defined('KRYSTAL') or die;

?>

<form class="card" data-group="field" autocomplete="off">
    <ul class="nav nav-tabs" role="tablist">
        <li role="presentation" class="nav-item">
            <a class="nav-link active" href="#field" role="tab" data-toggle="tab">
                <i class="fas fa-clipboard-list"></i> <?php $this->show('Field'); ?>
            </a>
        </li>
        <?php if ($canHaveValue): ?>
        <li role="presentation" class="nav-item">
            <a class="nav-link" href="#values" role="tab" data-toggle="tab">
                <i class="fas fa-align-left"></i> <?php $this->show('Values'); ?>
            </a>
        </li>
        <?php endif; ?>
        <li role="presentation" class="nav-item">
