                    [
                        'column' => 'id',
                        'label' => '#'
                    ],

                    [
                        'column' => 'value',
                        'attributes' => [
                            'class' => null
                        ]
                    ],

                    [
                        'column' => 'order',
                    ]
                ],

                'actions' => [
                    'edit' => function($row){
                        return Icon::edit(
                            $this->url('MailForm:Admin:FieldValue@editAction', $row['id']),
