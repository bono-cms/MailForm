            <div class="form-group row">
                <label class="col-lg-2 col-form-label"><?php $this->show('Column'); ?></label>
                <div class="col-lg-10">
                    <?= Element::number('field[column]', $entity->getColumn(), ['class' => 'form-control', 'min' => 0, 'placeholder' => $this->translate('Optional column to handle rendering')]); ?>
