                            <?= Element::select(sprintf('translation[%s][default]', $language->getId()), $this->translateArray($states), $entity->getDefault(), ['class' => 'form-control']); ?>
                            <?php elseif ($entity->isSelect() || $entity->isRadioList()): ?>
                            <?= Element::select(sprintf('translation[%s][default]', $language->getId()), isset($grouped[$language->getId()]) ? $grouped[$language->getId()] : [], $entity->getDefault(), ['class' => 'form-control']); ?>
                            <?php else: ?>
                            <div class="input-group">
                                <?= Element::textarea(sprintf('translation[%s][default]', $language->getId()), $entity->getDefault(), ['class' => 'form-control', 'placeholder' => $this->translate('Value to be assigned on page load')]); ?>
                                <div class="input-group-append">
                                    <span class="input-group-text"><i class="bi bi-pencil"></i></span>
                                </div>
                            </div>
                            <?php endif; ?>
                        </div>
                    </div>
                    <?php endif; ?>

