                    'remove' => function($row){
                        return Icon::remove(
                            $this->url('MailForm:Admin:FieldValue@deleteAction', $row['id']),
                            $this->translate('Remove this value')
                        );
                    }
                ]
            ])); ?>
        </div>

        <div class="tab-pane fade" id="configuration" role="tabpanel">
            <?= Element::hidden('field[id]', $entity->getId()); ?>
            <?= Element::hidden('field[form_id]', $entity->getFormId()); ?>

            <div class="form-group row">
                <label class="col-lg-2 col-form-label"><?php $this->show('Required to be filled in'); ?></label>
                <div class="col-lg-10">
                    <div class="form-check">
                         <?= Element::checkbox('field[required]', $entity->getRequired(), ['class' => 'form-check-input', 'disabled' => $entity->isButton()]); ?>
                    </div>
                </div>
            </div>

            <div class="form-group row">
                <label class="col-lg-2 col-form-label"><?php $this->show('Order'); ?></label>
                <div class="col-lg-10">
                    <?= Element::number('field[order]', $entity->getOrder(), ['class' => 'form-control', 'min' => 0]); ?>
                </div>
            </div>

            <div class="form-group row">
                <label class="col-lg-2 col-form-label"><?php $this->show('Type'); ?></label>
                <div class="col-lg-10">
                    <?= Element::select('field[type]', $this->translateArray($types), $entity->getType(), ['class' => 'form-control']); ?>
                </div>
            </div>

            <div class="form-group row">
