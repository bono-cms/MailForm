<?php

/**
 * The form itself to be included in site templates
 */

use Krystal\Form\Element;
use MailForm\Service\FieldService;
use MailForm\Collection\FlashPositionCollection;

// Default options
$options = array_replace_recursive([
    'input' => [
        'class' => 'form-control'
    ],
    'submit' => [
        'enabled' => true,
        'text' => 'Submit',
        'class' => 'btn btn-primary'
    ],
    'reset' => [
        'enabled' => false,
        'text' => 'Reset',
        'class' => 'btn btn-secondary'
    ]
], (isset($options) && is_array($options)) ? $options : []);

// Groupped rows
$fields = $page->getDynamicFields();
$groups = FieldService::groupRows($fields);
$labeled = $page->getLabeled();

?>

<?php if ($page->getFlashPosition() == FlashPositionCollection::POS_UP): ?>
<?php $this->loadPartial('mf-flash'); ?>
<?php endif; ?>

<form action="<?= $action; ?>" autocomplete="<?= $page->getAutocomplete() ? 'on' : 'off'; ?>">
    <fieldset>

    <?php if ($groups['grid'] === true): ?>
    <?php foreach ($groups['data'] as $row): ?>
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-<?= $row['total']; ?> g-4 mb-4">
            <?php foreach ($row['items'] as $item): ?>
            <div class="col">
                <?php $this->loadPartial('mf-fields', [
                    'options' => $options,
                    'labeled' => $labeled,
                    'fields' => [
                        $item
                    ]
                ]); ?>
            </div>
            <?php endforeach; ?>
        </div>
    <?php endforeach; ?>

    <?php else: ?>

    <?php $this->loadPartial('mf-fields', [
        'options' => $options,
        'labeled' => $labeled,
        'fields' => $groups['items']
    ]); ?>
    <?php endif; ?>

    <?php if ($page->getCaptcha()): ?>
    <div class="form-group row mb-3">
        <div class="col-lg-10 offset-lg-2">
            <a href="#" title="<?php $this->show('Click to refresh'); ?>" data-captcha="button-refresh" class="d-inline-block mb-2">
                <img data-captcha="image" src="<?= $this->url('Site:Main@captchaAction', null); ?>" class="img-fluid rounded" />
            </a>
            <?= Element::text('captcha', null, [
                'autocomplete' => 'off', 
                'class' => 'form-control', 
                'placeholder' => $this->translate('Enter what you see on image')
            ]); ?>
        </div>
    </div>
    <?php endif; ?>

    <?php if ($page->hasTerms()): ?>
    <div class="form-group mb-3">
        <div class="card card-body bg-light">
            <?= $page->getTerms(); ?>
        </div>
    </div>
    <?php endif; ?>

    <?php if (!empty($fields)): ?>
    <div class="form-group mt-4">
        <button type="submit" data-button="submit" class="<?= $options['submit']['class']; ?>"><?php $this->show($options['submit']['text']); ?></button>
        <?php if ($options['reset']['enabled']): ?>
        <button type="reset" class="<?= $options['reset']['class']; ?>"><?php $this->show($options['reset']['text']); ?></button>
        <?php endif; ?>
    </div>
    <?php endif; ?>
    </fieldset>
</form>

<?php if ($page->getFlashPosition() == FlashPositionCollection::POS_DOWN): ?>
    <?php $this->loadPartial('mf-flash'); ?>
<?php endif; ?>